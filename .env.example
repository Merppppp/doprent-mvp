# Copy to .env.local for local dev.

# --- PostgreSQL (Docker) ---
POSTGRES_USER=doprent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=doprent

# Next.js connects via PgBouncer (port 6432)
DATABASE_URL=postgresql://doprent:changeme@localhost:6432/doprent

# Direct connection (used by Prisma migrate / seed only — bypass PgBouncer)
DIRECT_DATABASE_URL=postgresql://doprent:changeme@localhost:5432/doprent

# --- Auth (NextAuth.js) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                      # openssl rand -base64 32

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (for verification emails) — e.g. Resend: https://resend.com
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=               # Resend API key
EMAIL_FROM=noreply@doprent.com

# --- LINE ---
NEXT_PUBLIC_DEFAULT_LINE_URL=https://line.me/R/ti/p/@doprent

# --- Object storage (S3-compatible: MinIO for dev/non-prod, Cloudflare R2 for prod) ---
# MinIO example:  S3_ENDPOINT=https://s3.doprent.com  S3_FORCE_PATH_STYLE=true
# R2 example:     S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com  S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public bucket (dress/listing photos)
S3_BUCKET=
# Base URL used to build public object URLs (e.g. https://media.doprent.com)
S3_PUBLIC_URL=
# Separate PRIVATE bucket for payment slips (no public domain). Served via
# short-lived presigned URLs. Falls back to S3_BUCKET if unset.
S3_PRIVATE_BUCKET=
# MinIO needs path-style addressing; R2 does not. Set to "true" for MinIO.
S3_FORCE_PATH_STYLE=false

# DEPRECATED (legacy fallback, removed next release) — prefer S3_* above.
# R2_ACCOUNT_ID=          # fallback endpoint https://{id}.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=       # fallback for S3_ACCESS_KEY_ID
# R2_SECRET_ACCESS_KEY=   # fallback for S3_SECRET_ACCESS_KEY
# R2_BUCKET_NAME=         # fallback for S3_BUCKET
# R2_PUBLIC_URL=          # fallback for S3_PUBLIC_URL
# R2_PRIVATE_BUCKET_NAME= # fallback for S3_PRIVATE_BUCKET

# --- Analytics (optional, production only) ---
PLATFORM_COMMISSION_RATE=0.10
IP_HASH_SALT=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_GA_ID=