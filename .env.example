# Copy to .env.local for local dev.

# --- PostgreSQL (Docker) ---
POSTGRES_USER=doprent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=doprent

# Next.js connects via PgBouncer (port 6432)
DATABASE_URL=postgresql://doprent:changeme@localhost:6432/doprent

# Direct connection (used by Prisma migrate / seed only — bypass PgBouncer)
DIRECT_DATABASE_URL=postgresql://doprent:changeme@localhost:5432/doprent

# --- Auth (NextAuth.js) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                      # openssl rand -base64 32

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (for verification emails) — e.g. Resend: https://resend.com
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=               # Resend API key
EMAIL_FROM=noreply@doprent.com

# --- LINE ---
NEXT_PUBLIC_DEFAULT_LINE_URL=https://line.me/R/ti/p/@doprent
