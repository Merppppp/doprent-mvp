/// แผนสมาชิกแบบเสียเงินของร้าน (เดิม seller_subscriptions) — ขับเคลื่อน MRR
model ShopSubscription {
  /// Primary key (uuid)
  id               String       @id @default(uuid()) @db.Uuid
  /// FK → shops.id (Cascade)
  shopId           String?      @map("shop_id") @db.Uuid
  /// FK → users.id เจ้าของ (SetNull)
  ownerId          String?      @map("owner_id") @db.Uuid
  /// แผนที่สมัคร
  plan             PlanTier     @default(free)
  /// สถานะ subscription
  status           SubStatus    @default(active)
  /// ยอดจ่ายต่อรอบ (บาท)
  amount           Int          @default(0)
  /// รอบบิล (รายเดือน/รายปี)
  billingCycle     BillingCycle @default(monthly) @map("billing_cycle")
  /// เวลาเริ่ม subscription
  startedAt        DateTime?    @default(now()) @map("started_at") @db.Timestamptz(6)
  /// เวลาสิ้นสุดรอบบิลปัจจุบัน
  currentPeriodEnd DateTime?    @map("current_period_end") @db.Timestamptz(6)
  /// เวลายกเลิก
  cancelledAt      DateTime?    @map("cancelled_at") @db.Timestamptz(6)

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop  Shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)
  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([status])
  @@index([plan])
  @@map("shop_subscriptions")
}

// ---------------------------------------------------------------------------
// Bookings (Phase 1: self-serve booking + PromptPay slip upload)
// ---------------------------------------------------------------------------

/// ที่อยู่จัดส่งของผู้ใช้
model Address {
  /// Primary key (uuid)
  id            String  @id @default(uuid()) @db.Uuid
  /// FK → users.id (Cascade)
  userId        String  @map("user_id") @db.Uuid
  /// ป้ายชื่อที่อยู่ (บ้าน/ที่ทำงาน)
  label         String
  /// ชื่อผู้รับ
  recipientName String  @map("recipient_name")
  /// เบอร์โทรผู้รับ
  phone         String
  /// ที่อยู่บรรทัดหลัก
  addressLine   String  @map("address_line")
  /// แขวง/ตำบล
  subdistrict   String?
  /// เขต/อำเภอ
  district      String?
  /// จังหวัด
  province      String? @default("กรุงเทพมหานคร")
  /// รหัสไปรษณีย์
  postalCode    String  @map("postal_code")
  /// ที่อยู่หลัก (default) ของผู้ใช้
  isDefault     Boolean @default(false) @map("is_default")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([userId])
  @@map("addresses")
}

/// การจอง — state machine 9 สถานะ, snapshot ราคา/ค่าคอม/ที่อยู่ ณ เวลาจอง
model Booking {
  /// Primary key (uuid)
  id               String         @id @default(uuid()) @db.Uuid
  /// FK → users.id ผู้เช่า (Cascade)
  renterId         String         @map("renter_id") @db.Uuid
  /// FK → shops.id (Cascade)
  shopId           String         @map("shop_id") @db.Uuid
  /// FK → products.id (Cascade)
  productId        String         @map("product_id") @db.Uuid
  /// วันเริ่มเช่า
  startDate        DateTime       @map("start_date") @db.Date
  /// วันคืนสินค้า
  endDate          DateTime       @map("end_date") @db.Date
  /// ค่าเช่ารวม snapshot ณ เวลาจอง (บาท)
  rentalTotal      Int            @map("rental_total")
  /// ค่ามัดจำ snapshot (บาท)
  deposit          Int            @default(0)
  /// ค่าส่ง (บาท)
  shippingFee      Int?           @map("shipping_fee")
  /// อัตราค่าคอมแพลตฟอร์ม snapshot (คงที่แม้ปรับ rate ภายหลัง)
  commissionRate   Decimal        @default(0.10) @map("commission_rate") @db.Decimal(5, 4)
  /// ยอดค่าคอมที่คำนวณแล้ว (บาท)
  commissionAmount Int?           @map("commission_amount")
  /// ช่องทาง acquisition (first-touch) ของผู้เช่า
  channel          String?
  /// สถานะการจองตาม state machine
  status           BookingStatus  @default(booking_pending)
  /// path ไฟล์สลิปโอนเงิน (private bucket)
  slipPath         String?        @map("slip_path")
  /// FK → addresses.id ที่อยู่ที่เลือกตอนจอง (SetNull — ใช้ snapshot ด้านล่างแสดงผล)
  addressId        String?        @map("address_id") @db.Uuid
  /// snapshot ชื่อผู้รับ
  recipientName    String?        @map("recipient_name")
  /// snapshot เบอร์โทร
  phone            String?
  /// snapshot ที่อยู่เต็ม (ข้อความ)
  addressText      String?        @map("address_text")
  /// เส้นตายของสถานะปัจจุบัน (เช่น หมดเวลาชำระเงิน)
  currentDueAt     DateTime?      @map("current_due_at") @db.Timestamptz(6)
  /// เหตุผลการยกเลิก
  cancelReason     String?        @map("cancel_reason")
  /// สถานะก่อนยกเลิก (เดิมเป็น String → ใช้ enum เดียวกับ status)
  cancelFromStatus BookingStatus? @map("cancel_from_status")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  renter  User     @relation(fields: [renterId], references: [id], onDelete: Cascade)
  shop    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  address Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@index([renterId])
  @@index([shopId])
  @@index([productId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("bookings")
}

