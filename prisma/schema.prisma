// ============================================================================
// DopRent — restructured schema (db-restructure Phase 1 DRAFT, rev 3)
// ----------------------------------------------------------------------------
// Conventions (see product/db-restructure/DESIGN.md):
//   * Every table: id uuid PK, created_by/updated_by uuid NULL (no FK — must
//     survive hard user deletes), created_at/updated_at timestamptz.
//   * updated_at is also maintained by ONE shared DB trigger set_updated_at()
//     (defined in migration SQL); Prisma @updatedAt kept where harmless.
//   * camelCase model fields ↔ snake_case columns via @map/@@map (unchanged).
//   * Hard delete everywhere; status enums below are real workflow states.
//   * /// doc comments here mirror COMMENT ON TABLE/COLUMN in migration SQL.
//   * rev 2 (host change orders): dresses→products, boutiques→shops,
//     saved_dresses→favorites, seller_subscriptions→shop_subscriptions,
//     dress_blackouts→product_blackout_dates; new product_types reference
//     table; admin_audit merged into audit_logs (model dropped).
//   * rev 3 (host change orders — taxonomy): new product_categories
//     (hierarchical, per product_type) + products.category_id (exactly ONE
//     category per product, nullable); new tag system (tag_groups / tags /
//     product_tags); occasions + product_occasions DROPPED — occasions become
//     tag_group key='occasion' with its tags seeded from the old occasion keys.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Reference tables
// ---------------------------------------------------------------------------

/// ตารางอ้างอิงประเภทสินค้าให้เช่า (เช่น dress, suit) — DopRent เป็นแพลตฟอร์มเช่าหลายประเภทสินค้า
model ProductType {
  /// Primary key (uuid)
  id       String  @id @default(uuid()) @db.Uuid
  /// Business key (เช่น "dress", "suit") — UNIQUE, ใช้ใน URL/filter
  key      String  @unique
  /// ชื่อแสดงผล (ไทย)
  label    String
  /// ปิดการใช้งานประเภทสินค้าโดยไม่ต้องลบ (FK เป็น RESTRICT — ห้ามลบถ้ามีสินค้าอ้างอยู่)
  isActive Boolean @default(true) @map("is_active")

  /// uuid ผู้สร้าง record (NULL = system/seed)
  createdBy String?  @map("created_by") @db.Uuid
  /// เวลาสร้าง record
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// uuid ผู้แก้ไขล่าสุด
  updatedBy String?  @map("updated_by") @db.Uuid
  /// เวลาแก้ไขล่าสุด (DB trigger set_updated_at + Prisma @updatedAt)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  products         Product[]
  categories       ProductCategory[]
  tagGroupBindings ProductTypeTagGroup[]

  @@map("product_types")
}

/// หมวดหมู่สินค้าแบบลำดับชั้น (dynamic, adjacency list) — ต้นไม้หมวดหมู่ 1 ต้นสังกัด 1 ประเภทสินค้า
/// (เช่น dress → ชุดราตรี/ชุดไทย, suit → สูทลำลอง) เพิ่ม/ย้ายหมวดได้โดยไม่ต้องแก้ schema
model ProductCategory {
  /// Primary key (uuid)
  id            String  @id @default(uuid()) @db.Uuid
  /// FK → product_categories.id หมวดแม่ (NULL = หมวดราก; RESTRICT — ห้ามลบหมวดที่ยังมีหมวดลูก, ดูเหตุผลใน DESIGN §3.2)
  parentId      String? @map("parent_id") @db.Uuid
  /// FK → product_types.id ประเภทสินค้าเจ้าของต้นไม้หมวดหมู่นี้ (RESTRICT — ปิดใช้งานผ่าน is_active แทนการลบ)
  productTypeId String  @map("product_type_id") @db.Uuid
  /// Business key (เช่น "evening-dress") — UNIQUE ทั้งระบบ, ใช้ใน URL/filter
  key           String  @unique
  /// ชื่อแสดงผล (ไทย)
  label         String
  /// ลำดับการแสดงผลภายในหมวดแม่เดียวกัน
  sortOrder     Int     @default(0) @map("sort_order")
  /// ปิดการใช้งานหมวดโดยไม่ต้องลบ
  isActive      Boolean @default(true) @map("is_active")

  /// uuid ผู้สร้าง record (NULL = system/seed)
  createdBy String?  @map("created_by") @db.Uuid
  /// เวลาสร้าง record
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// uuid ผู้แก้ไขล่าสุด
  updatedBy String?  @map("updated_by") @db.Uuid
  /// เวลาแก้ไขล่าสุด (DB trigger set_updated_at + Prisma @updatedAt)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    ProductCategory[] @relation("CategoryTree")
  productType ProductType       @relation(fields: [productTypeId], references: [id], onDelete: Restrict)
  products    Product[]

  @@index([parentId])
  @@index([productTypeId])
  @@map("product_categories")
}

/// กลุ่มแท็ก (เช่น color, style, occasion) — มิติ filter แบบ dynamic, เพิ่มกลุ่มใหม่ได้โดยไม่แก้ schema
/// (rev 3: ตาราง occasions เดิมถูกแทนด้วยกลุ่มแท็ก key='occasion')
model TagGroup {
  /// Primary key (uuid)
  id        String  @id @default(uuid()) @db.Uuid
  /// Business key (เช่น "occasion", "style") — UNIQUE
  key       String  @unique
  /// ชื่อแสดงผล (ไทย)
  label     String
  /// ลำดับการแสดงผลของกลุ่มใน UI filter
  sortOrder Int     @default(0) @map("sort_order")
  /// ปิดการใช้งานกลุ่มโดยไม่ต้องลบ
  isActive  Boolean @default(true) @map("is_active")

  /// uuid ผู้สร้าง record (NULL = system/seed)
  createdBy String?  @map("created_by") @db.Uuid
  /// เวลาสร้าง record
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// uuid ผู้แก้ไขล่าสุด
  updatedBy String?  @map("updated_by") @db.Uuid
  /// เวลาแก้ไขล่าสุด (DB trigger set_updated_at + Prisma @updatedAt)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tags                Tag[]
  tagRequests         TagRequest[]
  productTypeBindings ProductTypeTagGroup[]

  @@map("tag_groups")
}

/// แท็กในกลุ่ม (เช่น "wedding" ในกลุ่ม occasion) — แทน occasions เดิม + รองรับมิติใหม่ในอนาคต
model Tag {
  /// Primary key (uuid)
  id             String  @id @default(uuid()) @db.Uuid
  /// FK → tag_groups.id กลุ่มของแท็กนี้ (RESTRICT — ลบกลุ่มไม่ได้ถ้ายังมีแท็ก, ปิดผ่าน is_active)
  tagGroupId     String  @map("tag_group_id") @db.Uuid
  /// Business key (เช่น "wedding") — UNIQUE ทั้งระบบ, ใช้ใน URL/filter
  key            String  @unique
  /// ชื่อแสดงผล (ไทย)
  label          String
  /// ปิดการใช้งานแท็กโดยไม่ต้องลบ
  isActive       Boolean @default(true) @map("is_active")
  /// สีตัวอย่าง hex ใช้เฉพาะแท็กกลุ่ม color (เช่น "#D9A4A0") — NULL ถ้ากลุ่มอื่น
  swatchHex      String? @map("swatch_hex")
  /// รูป swatch สำหรับสีลาย/พื้นผิว — NULL ถ้าใช้ swatchHex แทน
  swatchImageUrl String? @map("swatch_image_url")

  /// uuid ผู้สร้าง record (NULL = system/seed)
  createdBy String?  @map("created_by") @db.Uuid
  /// เวลาสร้าง record
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// uuid ผู้แก้ไขล่าสุด
  updatedBy String?  @map("updated_by") @db.Uuid
  /// เวลาแก้ไขล่าสุด (DB trigger set_updated_at + Prisma @updatedAt)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tagGroup    TagGroup     @relation(fields: [tagGroupId], references: [id], onDelete: Restrict)
  productTags ProductTag[]

  @@index([tagGroupId])
  @@map("tags")
}

/// โหมดการเลือกแท็กในกลุ่มเมื่อผูกกับประเภทสินค้า (เลือกได้อันเดียว/หลายอัน)
enum TagSelectionMode {
  single
  multi

  @@map("tag_selection_mode")
}

/// ผูกกลุ่มแท็ก ↔ ประเภทสินค้า (dynamic subcategory/attribute) — กำหนดว่าแบบฟอร์มสินค้า
/// ของประเภทนั้น ๆ ต้องเรนเดอร์ช่องเลือกแท็กของกลุ่มใดบ้าง ลำดับ บังคับ และโหมดเลือก
/// (occasion = instance แรกของกลไกนี้ แทนการ hardcode)
model ProductTypeTagGroup {
  /// Primary key (uuid)
  id            String           @id @default(uuid()) @db.Uuid
  /// FK → product_types.id ประเภทสินค้าที่ผูก (RESTRICT — ห้ามลบประเภทถ้ายังมี binding; ปิดผ่าน is_active)
  productTypeId String           @map("product_type_id") @db.Uuid
  /// FK → tag_groups.id กลุ่มแท็กที่ผูก (RESTRICT — ห้ามลบกลุ่มถ้ายังมี binding)
  tagGroupId    String           @map("tag_group_id") @db.Uuid
  /// ลำดับการแสดง section ของกลุ่มนี้ในแบบฟอร์มสินค้าของประเภทนี้ (น้อย = แสดงก่อน)
  sortOrder     Int              @default(0) @map("sort_order")
  /// บังคับให้ผู้ขายเลือกอย่างน้อย 1 แท็กของกลุ่มนี้หรือไม่
  isRequired    Boolean          @default(false) @map("is_required")
  /// โหมดการเลือก: single = เลือกได้อันเดียว, multi = เลือกได้หลายอัน
  selectionMode TagSelectionMode @default(multi) @map("selection_mode")
  /// ปิดการใช้งาน binding โดยไม่ต้องลบ (ซ่อนกลุ่มจากแบบฟอร์มชั่วคราว)
  isActive      Boolean          @default(true) @map("is_active")

  /// uuid ผู้สร้าง record (NULL = system/seed)
  createdBy String?  @map("created_by") @db.Uuid
  /// เวลาสร้าง record
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// uuid ผู้แก้ไขล่าสุด
  updatedBy String?  @map("updated_by") @db.Uuid
  /// เวลาแก้ไขล่าสุด (DB trigger set_updated_at + Prisma @updatedAt)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  productType ProductType @relation(fields: [productTypeId], references: [id], onDelete: Restrict)
  tagGroup    TagGroup    @relation(fields: [tagGroupId], references: [id], onDelete: Restrict)

  @@unique([productTypeId, tagGroupId])
  @@index([productTypeId])
  @@index([tagGroupId])
  @@map("product_type_tag_groups")
}

/// ตารางอ้างอิงย่าน/พื้นที่ให้บริการ (เดิมกรุงเทพฯ) ใช้ค้นหาร้านใกล้เคียง
model Area {
  /// Primary key (uuid)
  id       String   @id @default(uuid()) @db.Uuid
  /// Business key เดิม (เช่น "siam") — UNIQUE, ใช้ใน URL/filter
  key      String   @unique
  /// ชื่อย่านภาษาไทย
  th       String
  /// ละติจูดจุดศูนย์กลางย่าน
  lat      Decimal  @db.Decimal(9, 6)
  /// ลองจิจูดจุดศูนย์กลางย่าน
  lng      Decimal  @db.Decimal(9, 6)
  /// คำค้นที่ map มาที่ย่านนี้
  keywords String[]
  /// ปิดการใช้งานย่านโดยไม่ต้องลบ
  isActive Boolean  @default(true) @map("is_active")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shops Shop[]

  @@map("areas")
}

// ---------------------------------------------------------------------------
// Users / Auth (NextAuth v5 + @auth/prisma-adapter — field names must stay
// adapter-compatible: User{id,name,email,emailVerified,image},
// Account{userId,type,provider,providerAccountId,refresh_token,...},
// Session{sessionToken,userId,expires}, VerificationToken{identifier,token,expires})
// ---------------------------------------------------------------------------

/// ผู้ใช้ทุกบทบาท (customer / seller / admin) — สร้างผ่าน NextAuth (Google) หรือ email+password
model User {
  /// Primary key (uuid) — อ้างโดย NextAuth JWT
  id             String    @id @default(uuid()) @db.Uuid
  /// อีเมล (UNIQUE) — NULL ได้กรณี provider ไม่ส่งอีเมล
  email          String?   @unique
  /// เวลายืนยันอีเมลสำเร็จ (NULL = ยังไม่ยืนยัน)
  emailVerified  DateTime? @map("email_verified") @db.Timestamptz(6)
  /// bcrypt hash สำหรับ login แบบ credentials (NULL = OAuth-only)
  passwordHash   String?   @map("password_hash")
  /// ชื่อ-นามสกุล — vocabulary ทั้งระบบคือ `fullName` (NextAuth adapter ส่ง `name` มา → map ใน adapter wrapper ที่ auth.ts)
  fullName       String?   @map("full_name")
  /// LINE id ของผู้ใช้ (ติดต่อกลับ)
  lineId         String?   @map("line_id")
  /// บทบาทในระบบ
  role           Role      @default(customer)
  /// URL รูปโปรไฟล์ (จาก OAuth)
  image          String?
  // -- Acquisition attribution (first-touch) + activity recency for MAU --
  /// utm_source แรกที่พามาสมัคร
  signupSource   String?   @map("signup_source")
  /// utm_medium แรก
  signupMedium   String?   @map("signup_medium")
  /// utm_campaign แรก
  signupCampaign String?   @map("signup_campaign")
  /// referrer แรก
  signupReferrer String?   @map("signup_referrer")
  /// ช่องทางที่สรุปแล้ว (organic/social/ads/...)
  signupChannel  String?   @map("signup_channel")
  /// เวลา activity ล่าสุด (ใช้คำนวณ MAU)
  lastActiveAt   DateTime? @map("last_active_at") @db.Timestamptz(6)
  /// จังหวัดล่าสุดที่ใช้งาน
  lastProvince   String?   @map("last_province")

  // -- Billing / tax-invoice profile (optional, renter-side) --
  /// ชื่อบริษัท/นิติบุคคล สำหรับออกใบกำกับภาษี (ไม่บังคับ)
  billingCompanyName String? @map("billing_company_name")
  /// เลขประจำตัวผู้เสียภาษี 13 หลัก (ไม่บังคับ)
  billingTaxId       String? @map("billing_tax_id")
  /// ที่อยู่สำหรับออกใบกำกับภาษี (ไม่บังคับ)
  billingAddress     String? @map("billing_address")
  /// สาขา เช่น สำนักงานใหญ่ / สาขา 00001 (ไม่บังคับ)
  billingBranch      String? @map("billing_branch")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  accounts          Account[]
  sessions          Session[]
  shops             Shop[]
  kycSubmissions    KycSubmission[]
  lineClicks        LineClick[]
  addresses         Address[]
  bookings          Booking[]
  pageViews         PageView[]
  shopSubscriptions ShopSubscription[]
  favorites         Favorite[]

  @@index([lastActiveAt(sort: Desc)])
  @@index([signupChannel])
  @@index([createdAt(sort: Desc)])
  @@map("users")
}

/// บทบาทผู้ใช้
enum Role {
  customer
  seller
  admin

  @@map("user_role")
}

/// บัญชี OAuth ที่ผูกกับผู้ใช้ (NextAuth adapter table — ห้ามเปลี่ยนชื่อ field มาตรฐาน)
model Account {
  /// Primary key (uuid)
  id                String  @id @default(uuid()) @db.Uuid
  /// FK → users.id
  userId            String  @map("user_id") @db.Uuid
  /// ชนิดบัญชี (oauth/email/credentials) — กำหนดโดย NextAuth
  type              String
  /// ชื่อ provider (google)
  provider          String
  /// id ผู้ใช้ฝั่ง provider
  providerAccountId String  @map("provider_account_id")
  /// OAuth refresh token
  refresh_token     String? @db.Text
  /// OAuth access token
  access_token      String? @db.Text
  /// เวลา access token หมดอายุ (epoch seconds)
  expires_at        Int?
  /// ชนิด token (bearer)
  token_type        String?
  /// OAuth scopes ที่ได้รับ
  scope             String?
  /// OIDC id_token
  id_token          String? @db.Text
  /// OAuth session_state
  session_state     String?

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

/// session ฝั่ง DB ของ NextAuth (ปัจจุบันใช้ JWT strategy — ตารางนี้แทบไม่ถูกเขียน แต่คงไว้ตาม adapter มาตรฐาน)
model Session {
  /// Primary key (uuid)
  id           String   @id @default(uuid()) @db.Uuid
  /// token ประจำ session (UNIQUE)
  sessionToken String   @unique @map("session_token")
  /// FK → users.id
  userId       String   @map("user_id") @db.Uuid
  /// เวลาหมดอายุ session
  expires      DateTime @db.Timestamptz(6)

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// token ยืนยันอีเมล (NextAuth standard + custom email-verify flow)
/// เดิม composite PK (identifier, token) → เพิ่ม id uuid PK, คง UNIQUE เดิมไว้
/// (@auth/prisma-adapter รุ่น >=2 ลบ field `id` ออกจากผลลัพธ์เองอยู่แล้ว — ปลอดภัย)
model VerificationToken {
  /// Primary key (uuid) — เพิ่มใหม่ตามมาตรฐานทุกตาราง
  id         String   @id @default(uuid()) @db.Uuid
  /// อีเมล/ตัวระบุผู้รับ token
  identifier String
  /// token (UNIQUE)
  token      String   @unique
  /// เวลาหมดอายุ token
  expires    DateTime @db.Timestamptz(6)

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Shops (เดิม boutiques)
// ---------------------------------------------------------------------------

/// ร้านให้เช่าสินค้า (เดิม boutiques) — 1 ร้านมีเจ้าของ 1 คน (owner), มีสินค้าหลายรายการ
model Shop {
  /// Primary key (uuid)
  id               String    @id @default(uuid()) @db.Uuid
  /// slug สำหรับ URL (UNIQUE)
  slug             String    @unique
  /// ชื่อร้าน
  name             String
  /// FK → users.id เจ้าของร้าน (SetNull เมื่อ user ถูกลบ)
  ownerId          String?   @map("owner_id") @db.Uuid
  /// ชื่อเจ้าของร้านที่แสดงผล (กรอกเอง — ไม่ใช่ snapshot ของ users.full_name)
  ownerName        String?   @map("owner_name")
  /// FK → areas.id ย่านที่ตั้งร้าน (เดิมอ้างด้วย area key string)
  areaId           String?   @map("area_id") @db.Uuid
  /// ป้ายชื่อย่านที่แสดงผล (รองรับย่านอิสระที่ไม่อยู่ใน areas)
  areaLabel        String    @map("area_label")
  /// ที่อยู่แบบข้อความเต็ม (legacy/รวม)
  address          String?
  /// บ้านเลขที่
  houseNo          String?   @map("house_no")
  /// ถนน/ซอย
  street           String?
  /// แขวง/ตำบล
  subdistrict      String?
  /// เขต/อำเภอ
  district         String?
  /// จังหวัด
  province         String    @default("กรุงเทพมหานคร")
  /// รหัสไปรษณีย์
  postalCode       String?   @map("postal_code")
  /// ละติจูดที่ตั้งร้าน
  lat              Decimal?  @db.Decimal(9, 6)
  /// ลองจิจูดที่ตั้งร้าน
  lng              Decimal?  @db.Decimal(9, 6)
  /// เวลาทำการ (ข้อความอิสระ)
  hours            String?
  /// LINE OA deep-link ของร้าน (CTA หลัก)
  lineUrl          String    @map("line_url")
  /// Instagram handle/URL
  instagram        String?
  /// PromptPay id รับเงิน (เบอร์/เลขบัตร ปชช.)
  promptpayId      String?   @map("promptpay_id")
  /// ปีที่เปิดร้าน
  sinceYear        Int?      @map("since_year")
  /// โทนสี cover การ์ดร้าน
  coverColor       Color     @default(rose) @map("cover_color")
  /// ป้าย tag การตลาดสั้น ๆ
  tag              String?
  /// เรื่องราว/คำแนะนำร้าน
  story            String?
  /// ข้อมูลการจัดส่ง
  deliveryInfo     String?   @map("delivery_info")
  /// ร้านแนะนำ (คัดโดย admin)
  featured         Boolean   @default(false)
  /// ระดับแผนโฆษณาปัจจุบันของร้าน
  adsTier          PlanTier  @default(free) @map("ads_tier")
  /// ผ่านการยืนยันตัวตนแล้ว (badge)
  verified         Boolean   @default(false)
  /// สถานะ workflow การเผยแพร่ร้าน
  status           Status    @default(live)
  /// เหตุผลเมื่อถูก reject
  rejectReason     String?   @map("reject_reason")
  /// สถานะ KYC ล่าสุด (rollup จาก kyc_submissions เพื่อ gate ฟีเจอร์เร็ว ๆ)
  kycStatus        KycStatus @default(none) @map("kyc_status")
  /// จำนวนวันล่วงหน้าขั้นต่ำที่ผู้เช่าต้องจอง (วันรับ >= วันนี้ + leadTimeDays)
  leadTimeDays     Int       @default(0) @map("lead_time_days")
  /// จำนวนวันเช่าขั้นต่ำต่อครั้ง
  minRentalDays    Int       @default(1) @map("min_rental_days")
  /// จำนวนวันเช่าสูงสุดต่อครั้ง (null = ไม่จำกัด)
  maxRentalDays    Int?      @map("max_rental_days")
  /// จำนวนวันที่ผู้เช่าต้องคืนสินค้าหลังวันสิ้นสุดการเช่า (แสดงต่อผู้เช่า)
  returnWindowDays Int       @default(2) @map("return_window_days")
  /// จำนวนวันบัฟเฟอร์หลังการเช่าแต่ละครั้ง (ช่วงเตรียม/ทำความสะอาด — บล็อกช่วง [start, end+bufferDaysAfter])
  bufferDaysAfter  Int       @default(2) @map("buffer_days_after")
  /// วันปิดทำการประจำสัปดาห์ (0=อาทิตย์..6=เสาร์) — ซ้ำทุกสัปดาห์
  closedWeekdays   Int[]     @default([]) @map("closed_weekdays")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner          User?              @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  area           Area?              @relation(fields: [areaId], references: [id], onDelete: SetNull)
  products       Product[]
  kycSubmissions KycSubmission[]
  lineClicks     LineClick[]
  bookings       Booking[]
  subscriptions  ShopSubscription[]
  closedDates    ShopClosedDate[]
  banners        Banner[]
  tagRequests    TagRequest[]

  @@index([status])
  @@index([featured])
  @@index([areaId])
  @@index([verified])
  @@index([district])
  @@map("shops")
}

// ---------------------------------------------------------------------------
// Products + child tables (เดิม dresses — normalized from Json/array columns)
// ---------------------------------------------------------------------------

/// สินค้าให้เช่า (เดิม dresses) — สินค้า 1 รายการของร้าน, แยกประเภทผ่าน product_types
/// เปลี่ยนแปลงสำคัญ: ตัด boutique_name (denormalized) ออก → join shops.name,
/// ย้าย images/price_tiers/occasions ออกเป็นตารางลูก, เพิ่ม product_type_id
model Product {
  /// Primary key (uuid)
  id               String                   @id @default(uuid()) @db.Uuid
  /// slug สำหรับ URL (UNIQUE)
  slug             String                   @unique
  /// รหัส tag ติดสินค้า (UNIQUE, สร้างอัตโนมัติ)
  tagCode          String                   @unique @map("tag_code")
  /// ชื่อสินค้า
  name             String
  /// ชื่อดีไซเนอร์/แบรนด์
  designer         String?
  /// FK → shops.id ร้านเจ้าของสินค้า
  shopId           String                   @map("shop_id") @db.Uuid
  /// FK → product_types.id ประเภทสินค้า (RESTRICT — ลบประเภทไม่ได้ถ้ามีสินค้าอ้างอยู่; ใช้ is_active แทน)
  productTypeId    String                   @map("product_type_id") @db.Uuid
  /// FK → product_categories.id หมวดหมู่ของสินค้า (host decision: สินค้า 1 ชิ้นมีได้ 1 หมวดเท่านั้น;
  /// NULL ได้ — สินค้าสร้างก่อนจัดหมวดได้; SET NULL — ลบหมวดแล้วสินค้ากลายเป็น "ยังไม่จัดหมวด", ดู DESIGN §3.2)
  categoryId       String?                  @map("category_id") @db.Uuid
  /// ไซซ์
  size             Size
  /// สีหลักของสินค้า (ใช้ filter) — nullable: สินค้าใหม่ใช้ ProductTag แทน; คอลัมน์ยังคงอยู่เพื่อ backward-compat
  color            Color?
  /// ราคาเช่าต่อวัน (บาท จำนวนเต็ม)
  pricePerDay      Int                      @map("price_per_day")
  /// ค่ามัดจำ (บาท)
  deposit          Int                      @default(0)
  /// คำอธิบายสินค้า
  description      String?
  /// LINE deep-link ของสินค้า (CTA หลัก)
  lineUrl          String                   @map("line_url")
  /// ระดับแผนโฆษณาของสินค้า
  adsTier          PlanTier                 @default(free) @map("ads_tier")
  /// สินค้าแนะนำ (คัดโดย admin)
  featured         Boolean                  @default(false)
  /// ติดป้าย sponsored
  sponsored        Boolean                  @default(false)
  /// สถานะ workflow การเผยแพร่สินค้า
  status           Status                   @default(live)
  /// เหตุผลเมื่อถูก reject
  rejectReason     String?                  @map("reject_reason")
  /// เปิดให้เช่าอยู่ (toggle โดยร้าน)
  available        Boolean                  @default(true)
  /// ตัวนับยอดเข้าชมหน้า detail
  views            Int                      @default(0)
  /// เมื่อ true ใช้ policy ของสินค้านี้เองแทน policy ของร้าน
  policyOverride   Boolean                  @default(false) @map("policy_override")
  /// override: จำนวนวันล่วงหน้าขั้นต่ำ (ใช้เมื่อ policyOverride = true; null = ใช้ค่าของร้าน)
  leadTimeDays     Int?                     @map("lead_time_days")
  /// override: จำนวนวันเช่าขั้นต่ำ (ใช้เมื่อ policyOverride = true; null = ใช้ค่าของร้าน)
  minRentalDays    Int?                     @map("min_rental_days")
  /// override: จำนวนวันเช่าสูงสุด (null + override = ไม่จำกัด; null + ไม่ override = ใช้ค่าของร้าน)
  maxRentalDays    Int?                     @map("max_rental_days")
  /// override: จำนวนวันคืนสินค้า (ใช้เมื่อ policyOverride = true; null = ใช้ค่าของร้าน)
  returnWindowDays Int?                     @map("return_window_days")
  /// override: จำนวนวันบัฟเฟอร์หลังเช่า (ใช้เมื่อ policyOverride = true; null = ใช้ค่าของร้าน)
  bufferDaysAfter  Int?                     @map("buffer_days_after")
  /// full-text search vector (จัดการผ่าน raw SQL/trigger)
  searchVector     Unsupported("tsvector")? @map("search_vector")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop        Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productType ProductType           @relation(fields: [productTypeId], references: [id], onDelete: Restrict)
  category    ProductCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  priceTiers  ProductPriceTier[]
  productTags ProductTag[]
  blackouts   ProductBlackoutDate[]
  lineClicks  LineClick[]
  bookings    Booking[]
  favoritedBy Favorite[]

  @@index([color])
  @@index([size])
  @@index([status])
  @@index([available])
  @@index([shopId])
  @@index([productTypeId])
  @@index([categoryId])
  @@index([pricePerDay])
  @@map("products")
}

/// รูปภาพของสินค้า (เดิมเก็บเป็น Json array ใน dresses.images)
model ProductImage {
  /// Primary key (uuid)
  id        String  @id @default(uuid()) @db.Uuid
  /// FK → products.id (Cascade)
  productId String  @map("product_id") @db.Uuid
  /// URL รูป (MinIO/R2)
  url       String
  /// ข้อความ alt สำหรับ accessibility/SEO
  alt       String?
  /// ลำดับการแสดง (0 = รูปหลัก/cover)
  sortOrder Int     @default(0) @map("sort_order")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_images")
}

/// ราคาเช่าแบบขั้นบันไดตามจำนวนวัน (เดิมเก็บเป็น Json ใน dresses.price_tiers)
model ProductPriceTier {
  /// Primary key (uuid)
  id          String @id @default(uuid()) @db.Uuid
  /// FK → products.id (Cascade)
  productId   String @map("product_id") @db.Uuid
  /// จำนวนวันขั้นต่ำที่ tier นี้เริ่มใช้
  minDays     Int    @map("min_days")
  /// ราคาต่อวันของ tier นี้ (บาท)
  pricePerDay Int    @map("price_per_day")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, minDays])
  @@map("product_price_tiers")
}

/// ตารางเชื่อมสินค้า↔แท็ก (rev 3: แทน product_occasions เดิม — เดิมสุดคือ String[] ใน dresses.occasions)
model ProductTag {
  /// Primary key (uuid)
  id        String @id @default(uuid()) @db.Uuid
  /// FK → products.id (Cascade)
  productId String @map("product_id") @db.Uuid
  /// FK → tags.id (Cascade)
  tagId     String @map("tag_id") @db.Uuid

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@index([tagId])
  @@map("product_tags")
}

/// สินค้าที่ผู้ใช้บันทึกไว้ (wishlist — เดิม saved_dresses / users.saved_dress_ids uuid[])
model Favorite {
  /// Primary key (uuid)
  id        String @id @default(uuid()) @db.Uuid
  /// FK → users.id (Cascade)
  userId    String @map("user_id") @db.Uuid
  /// FK → products.id (Cascade — ลบสินค้าแล้วรายการ favorite หายตาม, แก้ปัญหา id ค้างของ array เดิม)
  productId String @map("product_id") @db.Uuid

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("favorites")
}

// ---------------------------------------------------------------------------
// KYC
// ---------------------------------------------------------------------------

/// คำขอยืนยันตัวตนผู้ขาย (KYC) — 1 ร้านยื่นได้หลายครั้ง
/// เปลี่ยนแปลง: submitted_at เดิม → created_at มาตรฐาน
model KycSubmission {
  /// Primary key (uuid)
  id           String          @id @default(uuid()) @db.Uuid
  /// FK → shops.id (Cascade)
  shopId       String          @map("shop_id") @db.Uuid
  /// FK → users.id เจ้าของผู้ยื่น (SetNull)
  ownerId      String?         @map("owner_id") @db.Uuid
  /// ประเภทธุรกิจ (บุคคล/นิติบุคคล)
  businessType BusinessType    @map("business_type")
  /// ชื่อตามกฎหมาย (บุคคล/บริษัท)
  legalName    String          @map("legal_name")
  /// เลขประจำตัวผู้เสียภาษี
  taxId        String          @map("tax_id")
  /// เลขทะเบียน DBD (กรณีนิติบุคคล)
  dbdRegNo     String?         @map("dbd_reg_no")
  /// ธนาคารบัญชีรับเงิน
  bankName     String?         @map("bank_name")
  /// เลขบัญชีรับเงิน
  bankAccNo    String?         @map("bank_acc_no")
  /// ชื่อบัญชีรับเงิน
  bankAccName  String?         @map("bank_acc_name")
  /// URL เอกสารบัตรประชาชน (private bucket)
  idCardUrl    String?         @map("id_card_url")
  /// URL หนังสือรับรอง DBD
  dbdDocUrl    String?         @map("dbd_doc_url")
  /// URL หน้า book bank
  bookBankUrl  String?         @map("book_bank_url")
  /// URL ภ.พ.20 (VAT)
  vatDocUrl    String?         @map("vat_doc_url")
  /// แผนที่สมัครตอนยื่น KYC
  plan         PlanTier        @default(boost)
  /// สถานะการตรวจ KYC
  status       KycReviewStatus @default(pending)
  /// FK → users.id แอดมินผู้ตรวจ
  reviewerId   String?         @map("reviewer_id") @db.Uuid
  /// บันทึกผลการตรวจ
  reviewNotes  String?         @map("review_notes")
  /// เวลาที่ตรวจเสร็จ
  reviewedAt   DateTime?       @map("reviewed_at") @db.Timestamptz(6)

  /// uuid ผู้สร้าง record (= ผู้ยื่น)
  createdBy String?  @map("created_by") @db.Uuid
  /// เวลายื่นคำขอ (เดิมชื่อ submitted_at)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([shopId])
  @@map("kyc_submissions")
}

// ---------------------------------------------------------------------------
// Analytics (append-only, high volume)
// ---------------------------------------------------------------------------

/// เหตุการณ์คลิกปุ่ม LINE (success metric หลักของ v0.1) — append-only
/// เปลี่ยนแปลง: PK BigInt → uuid ตามมาตรฐานทุกตาราง
model LineClick {
  /// Primary key (uuid) — เดิม bigserial
  id        String  @id @default(uuid()) @db.Uuid
  /// FK → products.id สินค้าที่ถูกคลิก (SetNull)
  productId String? @map("product_id") @db.Uuid
  /// FK → shops.id ร้านที่ถูกคลิก (SetNull)
  shopId    String? @map("shop_id") @db.Uuid
  /// ตำแหน่งปุ่มบนหน้า (detail/card/...)
  source    String?
  /// FK → users.id ผู้คลิก (NULL = anonymous)
  userId    String? @map("user_id") @db.Uuid
  /// ช่องทาง acquisition ของ session
  channel   String?
  /// utm_source ของ session
  utmSource String? @map("utm_source")
  /// referrer ของ session
  referrer  String?
  /// จังหวัดผู้ใช้ (geo)
  province  String?
  /// session id ฝั่ง client
  sessionId String? @map("session_id")
  /// user agent
  userAgent String? @map("user_agent")
  /// hash ของ IP (privacy)
  ipHash    String? @map("ip_hash")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  shop    Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([shopId])
  @@index([channel])
  @@index([createdAt(sort: Desc)])
  @@map("line_clicks")
}

/// pageview ผู้เยี่ยมชม (anon + authed) — top-of-funnel analytics, append-only
/// เปลี่ยนแปลง: PK BigInt → uuid
model PageView {
  /// Primary key (uuid) — เดิม bigserial
  id          String  @id @default(uuid()) @db.Uuid
  /// session id ฝั่ง client
  sessionId   String? @map("session_id")
  /// FK → users.id (NULL = anonymous)
  userId      String? @map("user_id") @db.Uuid
  /// path ของหน้า
  path        String?
  /// ช่องทาง acquisition
  channel     String?
  /// utm_source
  utmSource   String? @map("utm_source")
  /// utm_medium
  utmMedium   String? @map("utm_medium")
  /// utm_campaign
  utmCampaign String? @map("utm_campaign")
  /// referrer
  referrer    String?
  /// จังหวัด (geo)
  province    String?
  /// ประเทศ (geo)
  country     String?
  /// user agent
  userAgent   String? @map("user_agent")
  /// hash ของ IP (privacy)
  ipHash      String? @map("ip_hash")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([channel])
  @@index([sessionId])
  @@index([userId])
  @@index([province])
  @@map("page_views")
}

// ---------------------------------------------------------------------------
