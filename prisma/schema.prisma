/// วันที่ร้านปิดไม่ให้จองสินค้า (blackout — เดิม dress_blackouts, composite PK (dress_id, date))
model ProductBlackoutDate {
  /// Primary key (uuid) — เพิ่มใหม่, คง UNIQUE(product_id, date)
  id        String   @id @default(uuid()) @db.Uuid
  /// FK → products.id (Cascade)
  productId String   @map("product_id") @db.Uuid
  /// วันที่ปิดจอง
  date      DateTime @db.Date

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([productId])
  @@index([date])
  @@map("product_blackout_dates")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

/// Audit log รวม (host decision: merge admin_audit เข้าตารางนี้)
/// 1) mechanical before/after ของทุก mutating operation — เขียนโดย Prisma client extension
/// 2) admin business actions (approve KYC, reject product, ...) — เขียน explicit
///    โดย admin actions; เหตุผลของแอดมินเก็บใน after->>'reason'
/// append-only, ไม่มี FK ไป users (ต้องอยู่รอดแม้ user ถูก hard delete)
model AuditLog {
  /// Primary key (uuid)
  id         String      @id @default(uuid()) @db.Uuid
  /// ชนิด operation (admin business actions ใช้ UPDATE/DELETE ตาม mutation จริง)
  action     AuditAction
  /// ชื่อ entity/ตาราง (เช่น "Product", "Booking") หรือ business entity ("kyc")
  entityType String      @map("entity_type")
  /// uuid ของ row ที่ถูกกระทำ
  entityId   String?     @map("entity_id") @db.Uuid
  /// uuid ผู้กระทำจาก session (NULL = system/cron/anonymous)
  actorId    String?     @map("actor_id") @db.Uuid
  /// สภาพ row ก่อนแก้ (NULL สำหรับ CREATE)
  before     Json?
  /// สภาพ row หลังแก้ (NULL สำหรับ DELETE); admin actions ใส่ reason/action ชื่อธุรกิจที่นี่
  after      Json?
  /// เวลาเกิดเหตุการณ์
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

/// ชนิด operation ใน audit_logs
enum AuditAction {
  CREATE
  UPDATE
  DELETE

  @@map("audit_action")
}

// ---------------------------------------------------------------------------
// Enums (workflow states — kept; hard delete policy means no "deleted" states)
// ---------------------------------------------------------------------------

/// โทนสีสินค้า/ร้าน (ใช้ filter + UI)
enum Color {
  rose
  ivory
  green
  black
  navy
  red
  blue
  purple

  @@map("color")
}

/// ไซซ์สินค้า
enum Size {
  XS
  S
  M
  L
  XL

  @@map("size")
}

/// ระดับแผน/โฆษณา — รวม AdsTier + KycPlan + SubPlan เดิมให้เหลือ enum เดียว
/// (KycPlan เดิมใช้ตัวพิมพ์ใหญ่ Free/Boost/Featured → migrate เป็นตัวเล็ก)
enum PlanTier {
  free
  boost
  featured

  @@map("plan_tier")
}

/// สถานะ workflow การเผยแพร่ (shop/product)
enum Status {
  pending
  live
  rejected
  draft

  @@map("listing_status")
}

/// สถานะ KYC rollup บนร้าน
enum KycStatus {
  none
  submitted
  verified
  rejected

  @@map("kyc_status")
}

/// สถานะการตรวจคำขอ KYC รายใบ
enum KycReviewStatus {
  pending
  approved
  rejected

  @@map("kyc_review_status")
}

/// ประเภทธุรกิจผู้ขาย
enum BusinessType {
  individual
  company

  @@map("business_type")
}

/// state machine การจอง
enum BookingStatus {
  booking_pending
  waiting_for_payment
  payment_review
  confirmed
  cancel_requested
  slip_disputed
  rejected
  cancelled
  payment_expired

  @@map("booking_status")
}

/// สถานะ subscription
enum SubStatus {
  active
  past_due
  cancelled
  expired

  @@map("sub_status")
}

/// รอบบิล subscription
enum BillingCycle {
  monthly
  yearly

  @@map("billing_cycle")
}
