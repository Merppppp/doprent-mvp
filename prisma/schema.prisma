/// ที่อยู่จัดส่งของผู้ใช้
model Address {
  /// Primary key (uuid)
  id            String  @id @default(uuid()) @db.Uuid
  /// FK → users.id (Cascade)
  userId        String  @map("user_id") @db.Uuid
  /// ป้ายชื่อที่อยู่ (บ้าน/ที่ทำงาน)
  label         String
  /// ชื่อผู้รับ
  recipientName String  @map("recipient_name")
  /// เบอร์โทรผู้รับ
  phone         String
  /// ที่อยู่บรรทัดหลัก
  addressLine   String  @map("address_line")
  /// แขวง/ตำบล
  subdistrict   String?
  /// เขต/อำเภอ
  district      String?
  /// จังหวัด
  province      String? @default("กรุงเทพมหานคร")
  /// รหัสไปรษณีย์
  postalCode    String  @map("postal_code")
  /// ที่อยู่หลัก (default) ของผู้ใช้
  isDefault     Boolean @default(false) @map("is_default")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([userId])
  @@map("addresses")
}

/// การจอง — state machine 9 สถานะ, snapshot ราคา/ค่าคอม/ที่อยู่ ณ เวลาจอง
model Booking {
  /// Primary key (uuid)
  id               String         @id @default(uuid()) @db.Uuid
  /// FK → users.id ผู้เช่า (Cascade)
  renterId         String         @map("renter_id") @db.Uuid
  /// FK → shops.id (Cascade)
  shopId           String         @map("shop_id") @db.Uuid
  /// FK → products.id (Cascade)
  productId        String         @map("product_id") @db.Uuid
  /// วันเริ่มเช่า
  startDate        DateTime       @map("start_date") @db.Date
  /// วันคืนสินค้า
  endDate          DateTime       @map("end_date") @db.Date
  /// ค่าเช่ารวม snapshot ณ เวลาจอง (บาท)
  rentalTotal      Int            @map("rental_total")
  /// ค่ามัดจำ snapshot (บาท)
  deposit          Int            @default(0)
  /// ค่าส่ง (บาท)
  shippingFee      Int?           @map("shipping_fee")
  /// อัตราค่าคอมแพลตฟอร์ม snapshot (คงที่แม้ปรับ rate ภายหลัง)
  commissionRate   Decimal        @default(0.10) @map("commission_rate") @db.Decimal(5, 4)
  /// ยอดค่าคอมที่คำนวณแล้ว (บาท)
  commissionAmount Int?           @map("commission_amount")
  /// ช่องทาง acquisition (first-touch) ของผู้เช่า
  channel          String?
  /// สถานะการจองตาม state machine
  status           BookingStatus  @default(booking_pending)
  /// path ไฟล์สลิปโอนเงิน (private bucket)
  slipPath         String?        @map("slip_path")
  /// FK → addresses.id ที่อยู่ที่เลือกตอนจอง (SetNull — ใช้ snapshot ด้านล่างแสดงผล)
  addressId        String?        @map("address_id") @db.Uuid
  /// snapshot ชื่อผู้รับ
  recipientName    String?        @map("recipient_name")
  /// snapshot เบอร์โทร
  phone            String?
  /// snapshot ที่อยู่เต็ม (ข้อความ)
  addressText      String?        @map("address_text")
  /// เส้นตายของสถานะปัจจุบัน (เช่น หมดเวลาชำระเงิน)
  currentDueAt     DateTime?      @map("current_due_at") @db.Timestamptz(6)
  /// เหตุผลการยกเลิก
  cancelReason     String?        @map("cancel_reason")
  /// สถานะก่อนยกเลิก (เดิมเป็น String → ใช้ enum เดียวกับ status)
  cancelFromStatus BookingStatus? @map("cancel_from_status")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  renter  User     @relation(fields: [renterId], references: [id], onDelete: Cascade)
  shop    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  address Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@index([renterId])
  @@index([shopId])
  @@index([productId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("bookings")
}

// ---------------------------------------------------------------------------
// Availability
// ---------------------------------------------------------------------------

/// วันที่ร้านปิดไม่ให้จองสินค้า (blackout — เดิม dress_blackouts, composite PK (dress_id, date))
model ProductBlackoutDate {
  /// Primary key (uuid) — เพิ่มใหม่, คง UNIQUE(product_id, date)
  id        String   @id @default(uuid()) @db.Uuid
  /// FK → products.id (Cascade)
  productId String   @map("product_id") @db.Uuid
  /// วันที่ปิดจอง
  date      DateTime @db.Date

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([productId])
  @@index([date])
  @@map("product_blackout_dates")
}

/// วันหยุดพิเศษ/วันปิดร้านแบบระบุวัน (one-off holidays) — mirror ของ product_blackout_dates แต่ระดับร้าน
model ShopClosedDate {
  /// Primary key (uuid)
  id     String   @id @default(uuid()) @db.Uuid
  /// FK → shops.id (Cascade)
  shopId String   @map("shop_id") @db.Uuid
  /// วันที่ปิดร้าน
  date   DateTime @db.Date
  /// หมายเหตุ (เช่น "วันสงกรานต์")
  note   String?

  /// uuid ผู้สร้าง record (NULL = system/seed)
  createdBy String?  @map("created_by") @db.Uuid
  /// เวลาสร้าง record
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// uuid ผู้แก้ไขล่าสุด
  updatedBy String?  @map("updated_by") @db.Uuid
  /// เวลาแก้ไขล่าสุด (DB trigger set_updated_at + Prisma @updatedAt)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
  @@index([shopId])
  @@index([date])
  @@map("shop_closed_dates")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

/// Audit log รวม (host decision: merge admin_audit เข้าตารางนี้)
/// 1) mechanical before/after ของทุก mutating operation — เขียนโดย Prisma client extension
/// 2) admin business actions (approve KYC, reject product, ...) — เขียน explicit
///    โดย admin actions; เหตุผลของแอดมินเก็บใน after->>'reason'
/// append-only, ไม่มี FK ไป users (ต้องอยู่รอดแม้ user ถูก hard delete)
model AuditLog {
  /// Primary key (uuid)
  id         String      @id @default(uuid()) @db.Uuid
  /// ชนิด operation (admin business actions ใช้ UPDATE/DELETE ตาม mutation จริง)
  action     AuditAction
  /// ชื่อ entity/ตาราง (เช่น "Product", "Booking") หรือ business entity ("kyc")
  entityType String      @map("entity_type")
  /// uuid ของ row ที่ถูกกระทำ
  entityId   String?     @map("entity_id") @db.Uuid
  /// uuid ผู้กระทำจาก session (NULL = system/cron/anonymous)
  actorId    String?     @map("actor_id") @db.Uuid
  /// สภาพ row ก่อนแก้ (NULL สำหรับ CREATE)
  before     Json?
  /// สภาพ row หลังแก้ (NULL สำหรับ DELETE); admin actions ใส่ reason/action ชื่อธุรกิจที่นี่
  after      Json?
  /// เวลาเกิดเหตุการณ์
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

/// ชนิด operation ใน audit_logs
enum AuditAction {
  CREATE
  UPDATE
  DELETE

  @@map("audit_action")
}

/// แบนเนอร์โฆษณา/โปรโมชั่นสำหรับ carousel หน้าหลัก (จัดการโดย admin)
model Banner {
  /// Primary key (uuid)
  id        String    @id @default(uuid()) @db.Uuid
  /// ชื่อแบนเนอร์ที่แสดงใน carousel
  title     String
  /// URL รูปภาพแบนเนอร์ (วาง URL ตรง ๆ)
  imageUrl  String    @map("image_url")
  /// URL ปลายทางเมื่อผู้ใช้คลิกแบนเนอร์ (null = ไม่ link)
  linkUrl   String?   @map("link_url")
  /// ลำดับการแสดงผลใน carousel (น้อย = แสดงก่อน)
  sortOrder Int       @default(0) @map("sort_order")
  /// เปิดใช้งานแบนเนอร์ (false = ซ่อน)
  isActive  Boolean   @default(true) @map("is_active")
  /// เวลาเริ่มแสดงแบนเนอร์ (null = ไม่กำหนด — แสดงทันที)
  startsAt  DateTime? @map("starts_at") @db.Timestamptz(6)
  /// เวลาสิ้นสุดการแสดงแบนเนอร์ (null = ไม่กำหนด — แสดงไม่มีกำหนด)
  endsAt    DateTime? @map("ends_at") @db.Timestamptz(6)
  /// FK → shops.id ร้านเจ้าของแบนเนอร์ (NULL = แบนเนอร์ระดับ admin/global; non-NULL = แบนเนอร์โปรโมชั่นร้านของ seller — ลบร้านแล้วแบนเนอร์หายตาม)
  shopId    String?   @map("shop_id") @db.Uuid
  /// สถานะการอนุมัติ: 'pending' (รออนุมัติ — seller สร้างใหม่) | 'approved' (อนุมัติแล้ว แสดงใน carousel) | 'rejected' (ปฏิเสธ); แบนเนอร์ admin ค่าเริ่มต้น 'approved'
  status    String    @default("approved")

  /// uuid ผู้สร้าง record (NULL = system/seed)
  createdBy String?  @map("created_by") @db.Uuid
  /// เวลาสร้าง record
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// uuid ผู้แก้ไขล่าสุด
  updatedBy String?  @map("updated_by") @db.Uuid
  /// เวลาแก้ไขล่าสุด (DB trigger set_updated_at + Prisma @updatedAt)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([isActive, sortOrder])
  @@index([shopId])
  @@map("banners")
}

// ---------------------------------------------------------------------------
// Tag Request (seller tag-request → admin approval)
// ---------------------------------------------------------------------------

/// enum สถานะคำขอเพิ่มแท็กจากผู้ขาย
enum TagRequestStatus {
  pending
  approved
  rejected

  @@map("tag_request_status")
}

/// คำขอเพิ่มแท็กใหม่จากผู้ขาย — รอแอดมินอนุมัติสร้าง Tag จริงในระบบ
/// เมื่ออนุมัติ: สร้าง Tag ใน tag_groups เท่านั้น — ไม่แนบกับสินค้าอัตโนมัติ (seller แนบเองทีหลัง)
model TagRequest {
  /// Primary key (uuid)
  id             String           @id @default(uuid()) @db.Uuid
  /// FK → tag_groups.id กลุ่มแท็กที่ขอเพิ่ม (RESTRICT — ห้ามลบกลุ่มถ้ายังมีคำขอ)
  tagGroupId     String           @map("tag_group_id") @db.Uuid
  /// FK → shops.id ร้านที่ยื่นคำขอ (CASCADE — ลบร้านแล้วคำขอหาย)
  shopId         String           @map("shop_id") @db.Uuid
  /// ชื่อแท็กที่ขอ (ภาษาไทย, บังคับ)
  requestedLabel String           @map("requested_label")
  /// slug แท็กที่เสนอ (ตัวเลือก — admin ยืนยันหรือกำหนดใหม่ตอนอนุมัติ)
  requestedKey   String?          @map("requested_key")
  /// สถานะการตรวจ: pending / approved / rejected
  status         TagRequestStatus @default(pending)
  /// uuid แอดมินผู้ตรวจ (ไม่มี FK — ต้องอยู่รอดแม้ user ถูก hard delete)
  reviewerId     String?          @map("reviewer_id") @db.Uuid
  /// บันทึกผลการตรวจ (เหตุผลตีกลับ หรือหมายเหตุ)
  reviewNotes    String?          @map("review_notes")
  /// เวลาที่แอดมินตัดสินใจ
  reviewedAt     DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  /// uuid ของ Tag ที่สร้างขึ้นเมื่ออนุมัติ (null = ยังไม่อนุมัติ; ไม่มี FK — ป้องกัน circular dependency)
  createdTagId   String?          @map("created_tag_id") @db.Uuid

  /// uuid ผู้สร้าง record (NULL = system/seed)
  createdBy String?  @map("created_by") @db.Uuid
  /// เวลาสร้าง record
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// uuid ผู้แก้ไขล่าสุด
  updatedBy String?  @map("updated_by") @db.Uuid
  /// เวลาแก้ไขล่าสุด (DB trigger set_updated_at + Prisma @updatedAt)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tagGroup TagGroup @relation(fields: [tagGroupId], references: [id], onDelete: Restrict)
  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tagGroupId])
  @@index([shopId])
  @@map("tag_requests")
}

// ---------------------------------------------------------------------------
// Enums (workflow states — kept; hard delete policy means no "deleted" states)
// ---------------------------------------------------------------------------

/// โทนสีสินค้า/ร้าน (ใช้ filter + UI)
enum Color {
  rose
  ivory
  green
  black
  navy
  red
  blue
  purple

  @@map("color")
}

/// ไซซ์สินค้า
enum Size {
  XS
  S
  M
  L
  XL

  @@map("size")
}

/// ระดับแผน/โฆษณา — รวม AdsTier + KycPlan + SubPlan เดิมให้เหลือ enum เดียว
/// (KycPlan เดิมใช้ตัวพิมพ์ใหญ่ Free/Boost/Featured → migrate เป็นตัวเล็ก)
enum PlanTier {
  free
  boost
  featured

  @@map("plan_tier")
}

/// สถานะ workflow การเผยแพร่ (shop/product)
enum Status {
  pending
  live
  rejected
  draft

  @@map("listing_status")
}

/// สถานะ KYC rollup บนร้าน
enum KycStatus {
  none
  submitted
  verified
  rejected

  @@map("kyc_status")
}

/// สถานะการตรวจคำขอ KYC รายใบ
enum KycReviewStatus {
  pending
  approved
  rejected

  @@map("kyc_review_status")
}

/// ประเภทธุรกิจผู้ขาย
enum BusinessType {
  individual
  company

  @@map("business_type")
}

/// state machine การจอง
enum BookingStatus {
  booking_pending
  waiting_for_payment
  payment_review
  confirmed
  cancel_requested
  slip_disputed
  rejected
  cancelled
  payment_expired
  /// ผู้เช่าคืนชุดแล้ว รอร้านตรวจรับ (terminal ของวงจรที่สำเร็จ ขั้นที่ 1)
  returned
  /// ร้านตรวจรับชุดเรียบร้อย ปิดรายการเช่าสมบูรณ์ (terminal สุดท้าย)
  completed

  @@map("booking_status")
}

/// สถานะ subscription
enum SubStatus {
  active
  past_due
  cancelled
  expired

  @@map("sub_status")
}

/// รอบบิล subscription
enum BillingCycle {
  monthly
  yearly

  @@map("billing_cycle")
}
