/// เหตุการณ์คลิกปุ่ม LINE (success metric หลักของ v0.1) — append-only
/// เปลี่ยนแปลง: PK BigInt → uuid ตามมาตรฐานทุกตาราง
model LineClick {
  /// Primary key (uuid) — เดิม bigserial
  id        String  @id @default(uuid()) @db.Uuid
  /// FK → products.id สินค้าที่ถูกคลิก (SetNull)
  productId String? @map("product_id") @db.Uuid
  /// FK → shops.id ร้านที่ถูกคลิก (SetNull)
  shopId    String? @map("shop_id") @db.Uuid
  /// ตำแหน่งปุ่มบนหน้า (detail/card/...)
  source    String?
  /// FK → users.id ผู้คลิก (NULL = anonymous)
  userId    String? @map("user_id") @db.Uuid
  /// ช่องทาง acquisition ของ session
  channel   String?
  /// utm_source ของ session
  utmSource String? @map("utm_source")
  /// referrer ของ session
  referrer  String?
  /// จังหวัดผู้ใช้ (geo)
  province  String?
  /// session id ฝั่ง client
  sessionId String? @map("session_id")
  /// user agent
  userAgent String? @map("user_agent")
  /// hash ของ IP (privacy)
  ipHash    String? @map("ip_hash")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  shop    Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([shopId])
  @@index([channel])
  @@index([createdAt(sort: Desc)])
  @@map("line_clicks")
}

/// pageview ผู้เยี่ยมชม (anon + authed) — top-of-funnel analytics, append-only
/// เปลี่ยนแปลง: PK BigInt → uuid
model PageView {
  /// Primary key (uuid) — เดิม bigserial
  id          String  @id @default(uuid()) @db.Uuid
  /// session id ฝั่ง client
  sessionId   String? @map("session_id")
  /// FK → users.id (NULL = anonymous)
  userId      String? @map("user_id") @db.Uuid
  /// path ของหน้า
  path        String?
  /// ช่องทาง acquisition
  channel     String?
  /// utm_source
  utmSource   String? @map("utm_source")
  /// utm_medium
  utmMedium   String? @map("utm_medium")
  /// utm_campaign
  utmCampaign String? @map("utm_campaign")
  /// referrer
  referrer    String?
  /// จังหวัด (geo)
  province    String?
  /// ประเทศ (geo)
  country     String?
  /// user agent
  userAgent   String? @map("user_agent")
  /// hash ของ IP (privacy)
  ipHash      String? @map("ip_hash")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([channel])
  @@index([sessionId])
  @@index([userId])
  @@index([province])
  @@map("page_views")
}

